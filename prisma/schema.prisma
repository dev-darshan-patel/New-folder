// Prisma schema for the booking SaaS.
// Production datasource: Postgres (Neon / Vercel Postgres). directUrl is the
// unpooled connection Prisma needs to run migrations against a PgBouncer-
// fronted connection string — Neon and Vercel Postgres both provide one.
// See docs/deploy.md for local setup now that SQLite has been retired.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// A business owner account. Each user is a tenant with their own booking page.
model User {
  id           String         @id @default(cuid())
  email        String         @unique
  // Nullable: accounts created via Google/Microsoft sign-in have no password
  // unless they later set one. Password login is rejected when this is null.
  passwordHash String?
  // Provider account ids for "Sign in with Google/Microsoft". An OAuth login
  // links to an existing account by verified email if these aren't set yet.
  googleId     String?        @unique
  microsoftId  String?        @unique
  name         String
  businessName String
  // Public URL handle, e.g. yoursaas.com/{slug}
  slug         String         @unique
  // IANA timezone, e.g. "America/New_York". Slots are generated in this zone.
  timezone     String         @default("UTC")
  // Legacy platform-admin flag. Superseded by `adminRole` (any non-null role
  // grants /admin access); kept only so existing rows aren't dropped.
  isAdmin      Boolean        @default(false)
  // Authoritative admin gate + permission level. null = not an admin.
  adminRole    AdminRole?
  // Blocks login + hides the public booking page. Distinct from soft-delete.
  suspended    Boolean        @default(false)
  // Soft-delete marker. Non-null = hidden from default lists, login blocked.
  // Set by admin hard-delete-adjacent soft-delete (restorable indefinitely) OR
  // by the self-service deletion cron once the grace period elapses (see
  // deletionRequestedAt below) — in the self-service case it also starts the
  // 30-day recovery window before permanent purge.
  deletedAt    DateTime?
  // Self-service account deletion: owner clicked "Delete my account". Account
  // stays fully ACTIVE during this window — nothing else changes, and a
  // dashboard banner offers instant one-click undo (no token needed, they're
  // still logged in). A cron tick past the grace period (see
  // src/lib/account-deletion.ts) does the actual destructive cascade (cancel
  // Stripe, cancel bookings + notify invitees, delete video meetings) and only
  // THEN sets deletedAt/purgeScheduledAt/recoveryToken below. Null = no
  // deletion in progress. Distinct from admin soft-delete, which skips this
  // grace state entirely and sets deletedAt directly.
  deletionRequestedAt DateTime?
  // Set once the grace period has elapsed and the destructive cascade has run.
  // Login is blocked from this point on (existing deletedAt semantics).
  // Recoverable via recoveryToken until purgeScheduledAt.
  purgeScheduledAt    DateTime?
  // One-time token emailed when deletedAt is set, letting the owner restore
  // the account (not the cancelled bookings/subscription) within the 30-day
  // window. Mirrors the passwordResetToken pattern below.
  recoveryToken       String?   @unique
  // One-time token + expiry for an admin-triggered password reset.
  passwordResetToken     String?   @unique
  passwordResetExpiresAt DateTime?
  // Optional mobile phone number for user contact/notifications.
  // Stored as free-form E.164-ish text — no automated verification yet.
  mobile                 String?

  // TOTP two-factor auth. Enabled only after the user confirms a code
  // during setup. Secret is the base32-encoded TOTP shared secret.
  totpSecret             String?
  totpEnabled            Boolean   @default(false)
  // JSON array of bcrypt-hashed one-time backup codes. Each is single-use;
  // remove from the array when consumed. Empty array or null = no codes issued.
  totpBackupCodes        String?

  // Email-address verification. Null = unverified (blocked from login for
  // password signups after this feature shipped; pre-existing accounts are
  // backfilled as verified). OAuth signups verify via the provider claim.
  emailVerifiedAt        DateTime?
  emailVerifyToken       String?   @unique
  emailVerifyExpiresAt   DateTime?
  // Session version. Embedded in every JWT; if the stored version is higher
  // than the JWT's, the session is rejected. Bumped on password change,
  // suspension, or admin force-logout so all existing sessions die instantly.
  tokenVersion           Int       @default(0)
  // Account-lockout counters. failedLoginAttempts resets on successful login;
  // lockedUntil blocks login attempts until it passes.
  failedLoginAttempts    Int       @default(0)
  lockedUntil            DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Billing / subscription. plan is the source of truth for feature gating and
  // is kept in sync with Stripe via webhooks.
  plan               String    @default("FREE")
  stripeCustomerId   String?   @unique
  stripeSubscriptionId String? @unique
  // Stripe subscription status, e.g. "active", "past_due", "canceled".
  subscriptionStatus String?
  // End of the current paid period; the plan stays active until this passes.
  planRenewsAt       DateTime?
  // True when the subscription is scheduled to cancel at planRenewsAt instead
  // of auto-renewing. Lets the billing page show "ends on" vs "renews on".
  cancelAtPeriodEnd  Boolean   @default(false)
  // When the tenant scheduled the cancellation (i.e. when cancelAtPeriodEnd
  // first flipped to true). Null once resumed or once the plan lapses.
  // Shown to admins in /admin/users so support can see who cancelled and when.
  planCancelRequestedAt DateTime?

  // Payments (Feature 4). Set at payment-application time; required before an
  // application can be approved because provider eligibility (Razorpay India-
  // only, Stripe elsewhere) depends on it. Country changes after approval
  // require re-approval.
  country               String?
  // NONE = tenant has not applied. APPLIED = waiting for admin review.
  // APPROVED = can onboard with a provider and set prices. SUSPENDED = admin
  // has revoked approval (fraud/complaint) — no new paid bookings allowed.
  paymentAccountStatus  String    @default("NONE")
  // Currently selected provider for new paid bookings. Historical bookings
  // permanently keep the provider they were paid through — see Booking's own
  // paymentProvider field. Null until the tenant picks one after approval.
  activePaymentProvider String?
  // Payment-provider account identifiers. Populated when the tenant starts
  // Stripe Connect Express / Razorpay Route onboarding (Phase 4.3). The
  // *Ready booleans reflect the provider's own "charges enabled" state — the
  // adapter refreshes them via getOnboardingStatus() after the tenant returns
  // from the hosted flow.
  stripeConnectAccountId   String?
  stripeConnectReady       Boolean @default(false)
  razorpayLinkedAccountId  String?
  razorpayConnectReady     Boolean @default(false)

  // Profile picture uploaded by the business owner (shown in dashboard + booking page).
  avatarUrl       String?

  // Branding (applied to the public booking page + embed). Custom values only
  // take effect on plans where customBranding is enabled; otherwise defaults.
  brandColor      String   @default("#4f46e5")
  brandFont       String   @default("Geist")
  logoUrl         String?
  welcomeMessage  String?

  eventTypes   EventType[]
  availability Availability[]
  bookings     Booking[]
  adminNotes        AdminNote[]
  couponRedemptions CouponRedemption[]
  teamMembers  TeamMember[]
  calendarConnections CalendarConnection[]
  dateOverrides DateOverride[]
  paymentApplications PaymentApplication[]
}

// One row per application a tenant submits to accept payments from their
// customers. New applications are only allowed while paymentAccountStatus is
// NONE (first time) or SUSPENDED/rejected (retry). Never edited once decided —
// resubmission creates a new row, preserving the audit trail.
model PaymentApplication {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Snapshot of the tenant's declared country at application time.
  country             String
  // Free-text business description shown to the admin reviewer.
  businessDescription String
  // Free-text expected price range, e.g. "$20-$100 per session".
  expectedPriceRange  String
  // PENDING = awaiting review. APPROVED / REJECTED are terminal for this row.
  status              String   @default("PENDING")
  reviewedByEmail     String?
  reviewedAt          DateTime?
  // Free-text rejection reason. Shown to the tenant so they know why.
  rejectionReason     String?
  createdAt           DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// A business owner's connected external calendar/video account (Google,
// Zoom, ...). Created via a per-user OAuth "connect" flow that is SEPARATE
// from login — these request offline access + a meeting-creation scope and
// store a refresh token so we can create video links on the owner's behalf.
// Login never stores tokens. One connection per (userId, provider) — an owner
// can connect Google AND Zoom at the same time.
model CalendarConnection {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "google" | "zoom"
  provider     String   @default("google")
  // The connected account's email, shown in the UI.
  accountEmail String
  // OAuth tokens. Stored as-is, matching the codebase's existing convention of
  // keeping provider secrets in the DB (see PlatformSettings). Refresh token is
  // long-lived; access token is refreshed when it nears expiry.
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  // Space-delimited granted scopes, for debugging/verification.
  scope        String?
  // Owner opt-out for busy-time sync (google only) — default on once the
  // connection has the required scope. Zoom connections ignore this field.
  syncBusyTimes Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
}

enum AssignmentMode {
  SOLO
  ROUND_ROBIN
  COLLECTIVE
}

model TeamMember {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  isOwner        Boolean   @default(false)
  active         Boolean   @default(true)
  lastAssignedAt DateTime?
  createdAt      DateTime  @default(now())

  availability   Availability[]
  eventTypes     EventTypeMember[]
  bookings       Booking[]

  @@index([userId])
}

model EventTypeMember {
  eventTypeId  String
  eventType    EventType  @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@id([eventTypeId, teamMemberId])
}

enum AdminRole {
  SUPER_ADMIN
  SUPPORT
  READ_ONLY
}

// Append-only record of every admin mutation, for accountability.
model AdminAuditLog {
  id           String   @id @default(cuid())
  actorId      String
  actorEmail   String
  action       String
  targetUserId String?
  // Snapshot of the target's business name at the time, in case it's later deleted.
  targetLabel  String?
  // JSON string of action-specific details (old/new values, reason, etc.).
  metadata     String?
  createdAt    DateTime @default(now())

  @@index([targetUserId])
  @@index([createdAt])
}

// An internal note left by a platform admin on a user's account.
// Visible only in /admin — never surfaced to the tenant.
model AdminNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  authorEmail String
  body      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// Subscription plans are now admin-editable rows, not a fixed enum. `User.plan`
// and `Coupon.grantPlan` store a Plan.id string. "FREE" is a reserved system
// plan that always exists and can't be deleted; code still treats
// plan == "FREE" as "not paying". Config is read via src/lib/plans.ts.
model Plan {
  id             String   @id
  name           String
  priceLabel     String
  // Monthly price in whole USD. 0 = free.
  priceMonthly   Int      @default(0)
  // Max active event types. null = unlimited.
  maxEventTypes  Int?
  customBranding Boolean  @default(false)
  teamScheduling Boolean  @default(false)
  // Bullet-point feature list shown on the billing page.
  features       String[]
  // Stripe recurring Price ID this plan checks out with (null for FREE).
  stripePriceId  String?
  active         Boolean  @default(true)
  sortOrder      Int      @default(0)
  // System plans (FREE) can't be deleted.
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// A bookable meeting type, e.g. "30 Minute Intro Call".
model EventType {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  // URL handle scoped to the user, e.g. /{userSlug}/{slug}
  slug            String
  description     String?
  durationMinutes Int       @default(30)
  // Minimum notice in minutes before a slot can be booked.
  bufferMinutes   Int       @default(0)
  // Max bookings allowed per calendar day for this event type. null = unlimited.
  maxPerDay       Int?
  // Max bookings allowed per calendar week (Sun-Sat, business timezone). null = unlimited.
  maxPerWeek      Int?
  // Max bookings allowed per calendar month (business timezone). null = unlimited.
  maxPerMonth     Int?
  // Minutes of notice required before the start time to self-cancel/reschedule.
  // 0 = no restriction. Only enforced for the invitee; the owner can always
  // cancel/reschedule (checked via getCurrentUser() ownership in the action).
  minNoticeToCancelMinutes Int @default(0)
  // Where to send the invitee after a successful booking, instead of the
  // built-in confirmation screen. Must be an absolute http(s) URL.
  confirmationRedirectUrl String?
  // Reply-to address for invitee-facing emails for this event type (e.g. a
  // shared support inbox). Falls back to the platform's default from-address
  // when null.
  replyToEmail    String?
  // When true, new bookings land as PENDING instead of CONFIRMED and the
  // owner must approve/reject them from the dashboard before they're final.
  requiresApproval Boolean @default(false)
  // When set, this is a GROUP event type: instead of auto-generating time slots
  // from weekly availability, the owner manually creates Session rows with a
  // fixed capacity, and many invitees can book into the same session up to that
  // capacity. null = classic 1:1 event type (unchanged behavior).
  capacity        Int?
  // When true, invitees can book this as a WEEKLY recurring series (same
  // weekday/time, fixed count). Only valid for classic 1:1 event types
  // (capacity == null, SOLO). null/false = single bookings only.
  allowRecurring  Boolean @default(false)
  // JSON array of custom intake questions: [{ label, required }].
  intakeQuestions String?
  active          Boolean        @default(true)
  assignmentMode  AssignmentMode @default(SOLO)
  // Where the meeting happens. GOOGLE_MEET/ZOOM auto-generate a video link at
  // booking time (requires the owner to have connected that provider).
  // Default IN_PERSON preserves existing behavior for all pre-existing rows.
  locationType    LocationType   @default(IN_PERSON)
  // Free-form detail: an address for IN_PERSON or a number for PHONE.
  // Unused for GOOGLE_MEET (the link is generated per booking).
  locationDetail  String?
  // Paid bookings (Feature 4.4). null = free (unchanged behavior). Any non-null
  // value requires the owner to be APPROVED + onboarded on their active
  // provider; the write-time re-check in updateEventTypeAction enforces this.
  // Currency is derived from the owner's active provider (Razorpay = INR,
  // Stripe = country default), stored per event type so switching providers
  // later doesn't silently re-denominate historical prices.
  priceCents      Int?
  currency        String?
  createdAt       DateTime  @default(now())

  bookings        Booking[]
  members         EventTypeMember[]
  sessions        Session[]

  @@unique([userId, slug])
}

enum LocationType {
  IN_PERSON
  PHONE
  GOOGLE_MEET
  ZOOM
}

// A concrete instance of a GROUP event type (EventType.capacity != null).
// Owner creates one per class/webinar occurrence: date + capacity. Many
// bookings can attach to the same session up to its capacity. Overbooking is
// prevented by an atomic UPDATE ... WHERE seatsTaken < capacity — see the
// group booking action.
model Session {
  id              String    @id @default(cuid())
  eventTypeId     String
  eventType       EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  // Stored in UTC. Duration comes from the event type — no endTime field so
  // there's no way for the two to drift out of sync.
  startTime       DateTime
  // Snapshot of the event type's duration at creation, so shortening the
  // event type later doesn't retroactively cut a session short.
  durationMinutes Int
  // Max attendees for this session. Snapshotted from EventType.capacity at
  // creation but editable per-session (e.g. one class has extra chairs).
  capacity        Int
  // Number of confirmed seats taken. Atomically incremented on book, decremented
  // on cancel. Never edited directly by application code — always via the
  // atomic UPDATE statements in the group booking + cancel actions.
  seatsTaken      Int       @default(0)
  // Shared video meeting URL for the whole session (all attendees join here).
  // Created at session-creation time when the event type is GOOGLE_MEET/ZOOM.
  meetingUrl      String?
  meetingProvider String?
  calendarEventId String?
  cancelled       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  bookings        Booking[]

  @@index([eventTypeId, startTime])
}

// A weekly-recurring availability window for a user.
// Stored as a weekday plus minutes-from-midnight in the user's timezone.
model Availability {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamMemberId String?
  teamMember   TeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  // 0 = Sunday ... 6 = Saturday
  weekday      Int
  // Minutes from midnight. e.g. 540 = 09:00, 1020 = 17:00
  startMinutes Int
  endMinutes   Int
}

// A one-off exception to the weekly Availability grid for a single calendar
// date — "closed July 20" or "open 10am-2pm this one Saturday" — without
// having to edit and restore the recurring weekly schedule.
model DateOverride {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // YYYY-MM-DD in the owner's timezone (same wall-clock convention as
  // Availability's weekday+minutes — timezone-naive, interpreted via
  // utcToZonedYmd at read time).
  date         String
  // "BLOCKED" = no slots at all that day. "CUSTOM_HOURS" = replace the day's
  // weekly windows with startMinutes/endMinutes for this date only.
  type         String
  startMinutes Int?
  endMinutes   Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, date])
}

// A confirmed booking made by an invitee on a user's booking page.
model Booking {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventTypeId  String
  eventType    EventType     @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  // For group event types only: which Session this booking attaches to. Null
  // for classic 1:1 bookings — those keep using the auto-generated slot flow.
  sessionId    String?
  session      Session?      @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  teamMemberId String?
  teamMember   TeamMember?   @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)
  inviteeName  String
  inviteeEmail String
  notes        String?
  // JSON array of answers to the event type's intake questions: [{ label, value }].
  answers      String?
  // JSON array of extra guests the invitee added: [{ name?, email }]. Each
  // gets its own ICS ATTENDEE line and a copy of the confirmation email.
  guests       String?
  // Stored in UTC.
  startTime    DateTime
  endTime      DateTime
  status       BookingStatus @default(CONFIRMED)
  // Random secret in the self-service manage URL (/booking/{manageToken}).
  // Nullable so pre-existing rows migrate cleanly; always set on new bookings.
  manageToken  String?       @unique
  // iCalendar SEQUENCE; incremented on each reschedule/cancel so calendar
  // clients update the existing event instead of creating a duplicate.
  sequence     Int           @default(0)
  // Number of times this booking has been rescheduled. Distinct from
  // `sequence` (which also increments on cancel) so admin analytics can
  // report an accurate reschedule rate.
  rescheduleCount Int        @default(0)
  // Timestamps marking which reminder emails have been sent (idempotency).
  remind24hSentAt DateTime?
  remind1hSentAt  DateTime?
  // Video URL generated at booking time for online event types. Null for
  // in-person/phone or when generation failed/was skipped.
  meetingUrl      String?
  // Which provider created meetingUrl/calendarEventId ("google" | "zoom"), so
  // reschedule/cancel call the right API. Null when no video link was created.
  meetingProvider String?
  // The provider-side meeting/event id backing this booking, so reschedule can
  // patch it and cancel can delete it. Null when no meeting was created.
  calendarEventId String?
  // Recurring series linkage. All occurrences of one weekly series share a
  // random seriesId (NOT a foreign key — no series table; each occurrence is a
  // fully independent Booking row). seriesIndex/seriesTotal are 1-based for
  // display ("Week 2 of 4"). All null for single (non-recurring) bookings.
  seriesId     String?
  seriesIndex  Int?
  seriesTotal  Int?

  // Feature 4.5: paid bookings. All null for free bookings (unchanged
  // behavior). paymentProvider is a snapshot of which provider processed the
  // payment — set once and never changed even if the tenant later switches
  // providers, so refunds/reversals hit the right API. amountCents+currency
  // are also snapshots at hold-creation time so tenant price edits mid-flight
  // don't mis-price a payment. providerPaymentId is Stripe's checkout session
  // id / Razorpay's payment-link id, used as the primary key for reconciling
  // webhooks + refund calls.
  paymentProvider     String?
  providerPaymentId   String?
  amountCents         Int?
  currency            String?
  // Money-side state, independent of the slot-side `status`. PENDING = customer
  // is at checkout. PAID = webhook confirmed. REFUNDED = refunded to the
  // customer (full or partial). EXPIRED = hold timed out. FAILED = webhook
  // reported a failure.
  paymentStatus       String?
  // Payout-side state (Feature 4.6). Initialized to HELD when payment succeeds.
  // Transitions: HELD → RELEASED (24h after appointment ends, cron transfers to
  // tenant), HELD → REFUNDED (customer refund while held, Phase 4.7), RELEASED
  // → REVERSED (post-release refund pulled back from tenant). RELEASE_FAILED is
  // an intermediate state the release cron retries.
  payoutStatus        String?
  // Provider's transfer id (Stripe transfer, Razorpay transfer). Populated
  // once payoutStatus flips to RELEASED so the reversal path can find it.
  transferId          String?
  releasedAt          DateTime?
  // Fee snapshot at release time — protects historical payouts from a later
  // paymentFeePercent change on PlatformSettings.
  platformFeeCents    Int?
  // Provider's error message on last release attempt, so /admin/payments can
  // surface why it failed without opening the provider's dashboard.
  payoutFailureReason String?
  // Bounded retry counter for RELEASE_FAILED bookings — cron ignores rows
  // once this hits the hard limit (currently 5) to avoid a runaway loop.
  payoutAttempts      Int      @default(0)
  createdAt    DateTime      @default(now())

  @@index([userId, startTime])
  @@index([seriesId])
  @@index([providerPaymentId])
  @@index([paymentStatus])
}

enum BookingStatus {
  CONFIRMED
  // Awaiting owner approval (requiresApproval event types only). Blocks the
  // slot the same as CONFIRMED so two people can't be approved into an
  // overlapping time. Becomes CONFIRMED on approval, CANCELLED on rejection.
  PENDING
  // Feature 4.5: booking exists, slot is held, customer is at the payment
  // provider's checkout. Becomes CONFIRMED on webhook success; CANCELLED on
  // hold expiry (~30 min) or explicit cancel. Blocks the slot like PENDING.
  PENDING_PAYMENT
  CANCELLED
}

enum StripeMode {
  TEST
  LIVE
}

// Singleton row (id is always "singleton") holding platform-wide Stripe
// configuration. Both test and live credentials can be stored at once, but
// only one mode is ever active — the app never falls back from one to the
// other. Secret-ish fields (secret keys, webhook secrets) are never echoed
// back to the admin UI in full; only a masked "ends in ####" hint is shown.
model PlatformSettings {
  id String @id @default("singleton")

  stripeMode StripeMode @default(TEST)

  stripeTestPublishableKey String?
  stripeTestSecretKey      String?
  stripeTestWebhookSecret  String?
  stripeTestPricePro       String?
  stripeTestPriceBusiness  String?

  stripeLivePublishableKey String?
  stripeLiveSecretKey      String?
  stripeLiveWebhookSecret  String?
  stripeLivePricePro       String?
  stripeLivePriceBusiness  String?

  // Payments (Feature 4). Razorpay platform-account credentials, mirroring the
  // Stripe test/live split. Populated after a Razorpay Route platform account
  // exists; test keys are enough to build/verify everything up to go-live.
  // Encrypted at rest via encryptIfConfigured (see src/lib/crypto.ts) — never
  // echoed back into the settings form (same pattern as Stripe secrets).
  razorpayMode           String  @default("TEST")
  razorpayTestKeyId      String?
  razorpayTestKeySecret  String?
  razorpayTestWebhookSecret String?
  razorpayLiveKeyId      String?
  razorpayLiveKeySecret  String?
  razorpayLiveWebhookSecret String?
  // Master switch for offering Stripe to Indian tenants. Default OFF because
  // Stripe's Indian marketplace onboarding is restricted — flip ON only after
  // verifying with a real test account. See Feature 4 eligibility matrix.
  stripeForIndiaEnabled  Boolean @default(false)
  // Percent taken from each paid booking's release amount, kept by the
  // platform. Configurable by an admin at any time.
  paymentFeePercent      Float   @default(0)

  // "Sign in with Google" OAuth app credentials.
  googleClientId     String?
  googleClientSecret String?

  // "Sign in with Microsoft" (Outlook/work-or-school) OAuth app credentials.
  microsoftClientId     String?
  microsoftClientSecret String?
  // Azure AD tenant to authorize against. "common" (the default) accepts both
  // personal Microsoft/Outlook accounts and work-or-school accounts.
  microsoftTenant       String  @default("common")

  // Zoom OAuth app credentials, for the per-owner "Connect Zoom" flow that
  // auto-generates Zoom meeting links (separate from any Zoom login).
  zoomClientId     String?
  zoomClientSecret String?

  // Platform-wide operational config (Phase 7).
  maintenanceMode    Boolean @default(false)
  maintenanceMessage String?
  signupsEnabled     Boolean @default(true)
  supportEmail       String?

  // Email delivery provider. Only one is active at a time. Falls back to
  // SMTP_* env vars when set to "NONE".
  emailProvider      String  @default("NONE")
  // Gmail SMTP (app password)
  gmailSmtpUser      String?
  gmailSmtpPass      String?
  gmailSmtpFrom      String?
  // Amazon SES SMTP credentials (generated at IAM → Security credentials → SMTP credentials)
  sesSmtpUser        String?
  sesSmtpPass        String?  // sensitive
  sesRegion          String?
  sesFromAddress     String?

  // Global branding applied to the shared HTML email shell (header/footer) that
  // wraps every transactional email. Null fields fall back to built-in defaults.
  emailBrandName    String?
  emailLogoUrl      String?
  emailAccentColor  String?
  emailFooterText   String?
  emailSupportUrl   String?

  updatedAt DateTime @updatedAt
}

// Toggleable product capabilities. Keys are stable identifiers checked in code.
model FeatureFlag {
  key         String   @id
  label       String
  description String?
  enabled     Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

// Admin-editable transactional email templates. Each row backs one send-site
// keyed by `key` (e.g. "booking.confirmed.invitee"). Rendered via
// src/lib/email-templates.ts with {{var}} substitution against a per-key
// whitelist. If a row is missing or disabled, the send-site falls back to its
// hardcoded default, so editing here never breaks delivery.
model EmailTemplate {
  key       String   @id
  // Grouping for the admin list: AUTH | ACCOUNT | BOOKING | NOTIFICATION.
  category  String
  // Human-readable label shown in the admin UI.
  name      String
  subject   String
  html      String
  text      String
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

enum CouponType {
  // Grants a paid plan for N days without Stripe checkout.
  TRIAL
  // Applies a Stripe promotion code at Checkout (requires stripePromotionCodeId).
  STRIPE_PROMO
}

// Admin-managed promo codes for billing.
model Coupon {
  id                    String     @id @default(cuid())
  code                  String     @unique
  description           String?
  type                  CouponType
  // TRIAL: number of days. STRIPE_PROMO: unused (0).
  value                 Int        @default(0)
  // TRIAL: plan to grant. STRIPE_PROMO: optional checkout plan filter.
  grantPlan             String?
  stripePromotionCodeId String?
  maxRedemptions        Int?
  redemptionCount       Int        @default(0)
  expiresAt             DateTime?
  active                Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  redemptions CouponRedemption[]
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  redeemedAt DateTime @default(now())

  @@unique([couponId, userId])
  @@index([userId])
}

// Platform-wide announcement banner shown to tenants in the dashboard.
// Written by admins at /admin/announcements. Only `active` rows render.
model Announcement {
  id        String   @id @default(cuid())
  message   String
  // Visual tone of the banner: INFO | WARNING | CRITICAL.
  level     String   @default("INFO")
  active    Boolean  @default(true)
  // Optional auto-expiry; null = shown until deactivated.
  expiresAt DateTime?
  createdBy String
  createdAt DateTime @default(now())
}

// Sliding-window rate-limit counters, shared across all serverless instances.
// Rows auto-expire and are cleaned up periodically by the rate-limit helper.
model RateLimit {
  // The rate-limit key, e.g. "login:192.168.1.1" or "login:user@example.com".
  key       String   @id
  // Number of attempts recorded in the current window.
  count     Int      @default(0)
  // When this window started.
  windowStart DateTime
  // When this row can be garbage-collected (windowStart + windowMs).
  expiresAt DateTime

  @@index([expiresAt])
}
