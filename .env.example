# Copy to .env and fill in. Postgres (Neon / Vercel Postgres) is required —
# see docs/deploy.md for how to get a free connection string in ~2 minutes.
#
# DATABASE_URL: pooled connection (PgBouncer) — used by the app at runtime.
# DIRECT_URL:   unpooled connection — used only by `prisma migrate`.
# Vercel's Postgres/Neon integration sets POSTGRES_PRISMA_URL and
# POSTGRES_URL_NON_POOLING automatically; if you use it, point these two at
# those instead of retyping the connection string.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Long random string used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# Base URL used when building public booking links and email content.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SMTP for outgoing email. Leave SMTP_HOST blank to log emails to the console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Booking <no-reply@example.com>"

# Stripe billing is primarily configured at runtime via the platform admin
# console (/admin/settings), which stores test AND live credentials in the
# database and lets a Super Admin switch between them without redeploying.
# These env vars are only a zero-config fallback for TEST mode and are
# ignored once a key is set in /admin/settings.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_BUSINESS=""

# Secret protecting the reminder cron endpoint (/api/cron/reminders).
CRON_SECRET="change-me"
